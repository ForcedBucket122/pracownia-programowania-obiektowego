<Window x:Class="projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:projekt"
        mc:Ignorable="d"
        x:Name="okno"
        Title="MainWindow" Height="450" Width="800">
    <Canvas x:Name="canvas">
        <Image Source="/grafika/DOG.png" x:Name="doh" Canvas.Left="300px" Canvas.Top="100px" Width="200px" MouseDown="doh_MouseDown" MouseUp="MouseUp" MouseMove="MouseMove"/>
        <Button x:Name="Top" Content="góra" Canvas.Left="380px" Canvas.Top="320px" Width="60px" FontSize="20px" Click="Top_Click" />
        <Button x:Name="Bottom" Content="dół" Canvas.Left="380px" Canvas.Top="380px" Width="60px" FontSize="20px" Click="Bottom_Click"/>
        <Button x:Name="Left" Content="lewo" Canvas.Left="300px" Canvas.Top="350px" Width="60px" FontSize="20px" Click="Left_Click"/>
        <Button x:Name="Right" Content="prawo" Canvas.Left="460px" Canvas.Top="350px" Width="60px" FontSize="20px" Click="Right_Click"/>
    </Canvas>
</Window>
